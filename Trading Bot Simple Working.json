      "parameters": {
        "functionCode": "const crypto = $node[\"Get Crypto\"].json;\nconst gold = $node[\"Get Gold\"].json;\n\n// BTC latest price\nconst btcPrice = crypto.prices[crypto.prices.length - 1][1];\n\n// Fix gold type\nconst goldPrice = parseFloat(gold.price || gold.data?.price || 0);\n\n// Silver fallback\nconst silverPrice = 0;\n\nreturn [{\n  btc: parseFloat(btcPrice.toFixed(2)),\n  gold: parseFloat(goldPrice.toFixed(2)),\n  silver: silverPrice\n}];"
      },
